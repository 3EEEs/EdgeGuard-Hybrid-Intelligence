---
const { awsStatus = "OK", used = 0, max = 200 } = Astro.props;
---

<div class="status-bar">
  <div>AWS Status: <span class="value">{awsStatus}</span></div>
  <div>
    Cloud Budget: <span class="value" id="budget-display">${used}/{max}</span>
  </div>
</div>

<script>
  // This code runs in the browser, not on the server
  const budgetSpan = document.getElementById("budget-display");

  async function syncBudget() {
    try {
      const response = await fetch("http://127.0.0.1:5000/get_budget");
      if (!response.ok) throw new Error("Backend unreachable");

      const data = await response.json();

      if (budgetSpan) {
        // Update the text dynamically
        budgetSpan.textContent = `$${data.spent.toFixed(3)}/${data.limit}`;

        // Bonus: Turn text red if you're close to the limit
        if (data.spent > data.limit * 0.9) {
          budgetSpan.style.color = "#ff4d4d";
        }
      }
    } catch (err) {
      console.warn("Budget fetch failed. Backend might be offline.");
    }
  }
  // Sync every 3 seconds so you see changes quickly during your demo
  setInterval(syncBudget, 3000);

  // Also run it once immediately on load
  syncBudget();
</script>

<style>
  .status-bar {
    display: flex;
    gap: 2rem;
    background: #1a1d24;
    padding: 1rem;
    border-radius: 8px;
    border: 1px solid #2a2d34;
    font-size: 1rem;
  }

  .value {
    font-weight: 600;
  }
</style>
