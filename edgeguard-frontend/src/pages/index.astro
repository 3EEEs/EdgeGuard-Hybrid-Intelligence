---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import Navbar from "../components/Navbar.astro";
import StatusBar from "../components/StatusBar.astro";
import LiveFeed from "../components/LiveFeed.astro";
import CustomPanel from "../components/CustomPanel.astro";

// 1. Import your new React components
import Filter_Control from "../components/Filter_Control.jsx";
import Event_Feed from "../components/Event_Feed.jsx";
---

<DashboardLayout title="EdgeGuard Dashboard">
  <Navbar slot="navbar" />

  <StatusBar awsStatus="OK" used={42} max={100} />

  <div class="grid">
    <LiveFeed />
    
    <Filter_Control client:load />

    <Event_Feed client:load />
    
    <CustomPanel title="Shortcut Panel" />
  </div>
</DashboardLayout>

<style>
  /* Your existing grid styles remain the same */
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-template-rows: repeat(2, 1fr);
    gap: 0.75rem;
    height: calc(100vh - 130px);
    width: 100%;
  }
</style>