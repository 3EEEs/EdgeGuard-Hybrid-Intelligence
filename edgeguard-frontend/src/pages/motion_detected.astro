---
import DashboardLayout from "../layouts/DashboardLayout.astro";
import Navbar from "../components/Navbar.astro";
import StatusBar from "../components/StatusBar.astro";

// We'll eventually create this component to show the AWS S3 captures
import CloudGallery from "../components/CloudGallery.jsx";
---

<DashboardLayout title="EdgeGuard - Motion Detected">
    <Navbar slot="navbar" />

    <StatusBar awsStatus="OK" used={12} max={500} />

    <div class="gallery-container">
        <h1>Cloud Captures</h1>
        <p>Viewing latest motion events stored in S3</p>

        <CloudGallery client:load />
    </div>
</DashboardLayout>

<style>
    .gallery-container {
        padding: 1.5rem;
        color: white;
    }

    h1 {
        font-size: 1.5rem;
        margin-bottom: 0.5rem;
    }

    p {
        opacity: 0.7;
        margin-bottom: 2rem;
    }
</style>
