---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
    <link rel="stylesheet" href="/global.css" />
  </head>

  <body>
    <slot name="navbar" />

    <main class="dashboard-container">
      <slot />
    </main>
  </body>
</html>

<style>
  body {
    margin: 0;
    background: #0f1116;
    color: #e5e5e5;
    font-family: system-ui, sans-serif;
  }

  /* extremely compact layout */
  .dashboard-container {
    padding: 0.25rem 0.75rem;   /* was 1rem */
    display: grid;
    gap: 0.5rem;                /* was 1rem */
  }
</style>



